# Rooben environment configuration
#
# `make demo` needs NONE of these — it runs the full stack with a seeded
# workflow offline. Set these when you want to run real workflows with live
# LLM providers or external integrations.

# ── LLM providers (pick at least one for real workflows) ──────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Database (required for dashboard) ─────────────────────────────────────────
# The compose stack provides this automatically. Override for external DBs.
DATABASE_URL=postgresql://rooben:rooben@localhost:5432/rooben

# ── API authentication (optional) ─────────────────────────────────────────────
# Comma-separated keys; leave empty to disable auth for local development.
ROOBEN_API_KEYS=
